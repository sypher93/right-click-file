#!/bin/bash
# right-click-file | Copyright (C) 2026 sypher93 <sypher93@proton.me> | GPLv3
set -e

LOG_DIR="/var/log/right_click_file"
LOG_FILE="$LOG_DIR/install.log"
STATE_DIR="/var/lib/right-click-file"
BACKUP_DIR="$STATE_DIR/backups"
DING_FILE="/usr/share/gnome-shell/extensions/ding@rastersoft.com/app/desktopManager.js"
ORIGINAL_BACKUP="$STATE_DIR/desktopManager.js.original"
APT_HOOK_CONF="/etc/apt/apt.conf.d/99-right-click-file"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$1] $2" >> "$LOG_FILE"
    echo "[$1] $2"
}

mkdir -p "$LOG_DIR"
chmod 755 "$LOG_DIR"
mkdir -p "$STATE_DIR"
mkdir -p "$BACKUP_DIR"
chmod 755 "$STATE_DIR" "$BACKUP_DIR"

{
    echo ""
    echo "================================================================"
    echo "  right-click-file v1.2.0 -- postinst $(date '+%Y-%m-%d %H:%M:%S')"
    echo "================================================================"
} >> "$LOG_FILE"

log "INFO" "Running post-installation tasks..."

# --- Patch DING ---
if [ ! -f "$DING_FILE" ]; then
    log "WARN" "DING not found, skipping desktop patch: $DING_FILE"
else

    if grep -q "PATCH_CREATE_FILE_HERE" "$DING_FILE"; then
        log "WARN" "Residual patch detected in DING file -- cleaning before backup"
        python3 /usr/share/right-click-file/patch-ding.py remove >> "$LOG_FILE" 2>&1 \
            && log "OK" "Residual patch cleaned successfully" \
            || log "WARN" "Could not clean residual patch -- original backup may be tainted"
    fi

    if [ ! -f "$ORIGINAL_BACKUP" ]; then
        cp "$DING_FILE" "$ORIGINAL_BACKUP"
        chmod 444 "$ORIGINAL_BACKUP"
        log "INFO" "Original backup saved (read-only): $ORIGINAL_BACKUP"
    else
        log "INFO" "Original backup already exists, skipping: $ORIGINAL_BACKUP"
    fi

    python3 /usr/share/right-click-file/patch-ding.py apply >> "$LOG_FILE" 2>&1 \
        && log "OK" "DING patch applied" \
        || log "WARN" "DING patch failed -- check $LOG_FILE"

    sha256sum "$DING_FILE" | awk '{print $1}' > "$STATE_DIR/ding.sha256"
    log "INFO" "DING hash stored: $(cat "$STATE_DIR/ding.sha256")"
fi

if [ -f "$APT_HOOK_CONF" ]; then
    log "INFO" "apt hook already present, skipping"
else
    cp /usr/share/right-click-file/apt-hook.conf "$APT_HOOK_CONF"
    chmod 644 "$APT_HOOK_CONF"
    log "OK" "apt hook installed: $APT_HOOK_CONF"
fi

{
    echo "DING_FILE=$DING_FILE"
} > "$LOG_DIR/installed_files.txt"

log "OK" "Post-installation complete"
log "INFO" "A reboot is required for the desktop right-click to become active"

exit 0